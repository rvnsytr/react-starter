{
  "files.readonlyInclude": {
    "**/src/core/**": true,

    "**/src/router.tsx": true,
    "**/src/routeTree.gen.ts": true,

    "**/src/routes/__root.tsx": true,
    "**/src/routes/dashboard/route.tsx": true,

    "**/src/modules/auth/**": true,
    "**/src/modules/activity/**": true
  },

  "files.watcherExclude": { "**/routeTree.gen.ts": true },
  "search.exclude": { "**/routeTree.gen.ts": true, "**/dist/**": true },

  "js/ts.preferences.autoImportFileExcludePatterns": ["@base-ui/react"],

  "js/ts.preferences.importModuleSpecifier": "shortest"
}
